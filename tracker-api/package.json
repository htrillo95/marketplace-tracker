{
  "name": "tracker-api",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "start:prod": "prisma migrate deploy && node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "facebook:poc": "tsx src/scripts/facebook-poc.ts",
    "facebook:auth": "tsx src/scripts/facebook-auth.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "express": "^5.1.0",
    "playwright": "^1.61.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.13.2",
    "prisma": "^6.19.3",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
