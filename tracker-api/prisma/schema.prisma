generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SavedSearch {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  createdAt DateTime @default(now())
}

model Listing {
  id         String   @id @default(uuid()) @db.Uuid
  source     String
  listingUrl String   @unique
  title      String?
  price      String?
  location   String?
  imageUrl   String?
  seenAt     DateTime @default(now())
}
