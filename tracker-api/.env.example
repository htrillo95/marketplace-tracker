# Neon (or local) PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Railway sets PORT automatically. Local default is 3000.
PORT=3000

# Comma-separated frontend origins for CORS.
# Leave unset for local development (allows any origin).
# Production example:
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173
CORS_ORIGINS=

# Optional Facebook Marketplace scraper settings
MARKETPLACE_LOCATION="philly"
MARKETPLACE_RADIUS="65"
MARKETPLACE_HEADLESS="true"
